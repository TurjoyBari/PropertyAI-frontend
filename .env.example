# Public app URL (browser origin — auth cookies are first-party here)
# Local:  http://localhost:3000
# Vercel: https://YOUR_PROJECT.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend API base URL (Next.js rewrites /api/* here at build time)
# Local:   http://localhost:4000
# Deployed: https://YOUR_API_HOST (Railway / Render / Fly / VPS)
NEXT_PUBLIC_API_URL=http://localhost:4000
